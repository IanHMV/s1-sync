# ===== Conexion a Mongo (la misma instancia de tu stack) =====
# Usa el usuario root, o uno con readWrite sobre las bases s1-api y s1-sync.
SYNC_MONGO_HOST=s1-database
SYNC_MONGO_PORT=27017
SYNC_MONGO_USER=
SYNC_MONGO_PASS=
SYNC_MONGO_AUTHDB=admin

# Base/coleccion DESTINO (la que lee tu s1-api). No cambiar salvo que tu deploy difiera.
S1_DB_NAME=s1-api
S1_COLLECTION=declaraciones

# Base de metadatos del propio sync (catalogo de entes + bitacora)
SYNC_DB_NAME=s1-sync

# Llave de cifrado para credenciales de los entes (32 bytes).
# Genera una con:  npm run genkey   (o: openssl rand -hex 32)
SYNC_ENC_KEY=

# Programacion: dias 1 y 16 a las 3am (aprox. cada 15 dias)
SYNC_CRON=0 3 1,16 * *
SYNC_TZ=America/Mexico_City

# Corre una sincronizacion al arrancar (util para la PRIMERA carga; luego ponlo en false)
SYNC_RUN_ON_START=false

# Ajustes de paginado y resiliencia
SYNC_PAGE_SIZE=100
SYNC_HTTP_TIMEOUT_MS=30000
SYNC_MAX_RETRIES=3
SYNC_UPSERT_BATCH=500

SYNC_LOG_LEVEL=info
